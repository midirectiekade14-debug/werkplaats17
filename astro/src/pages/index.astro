---
import BaseLayout from '../layouts/BaseLayout.astro';
import Floorplan from '../components/Floorplan.astro';
import { content } from '../data/content';
import heroSvg from '../components/_hero-svg.html?raw';
import photoStripSvg from '../components/_photostrip-svg.html?raw';

const whatsappHref =
  'https://wa.me/' +
  content.whatsappNumber +
  '?text=' +
  encodeURIComponent(content.whatsappText);
---

<BaseLayout>
  <!-- STICKY NAV -->
  <nav class="sticky-nav" id="stickyNav">
    <div class="sticky-nav-inner">
      <a href="#top" class="nav-brand">Werk<span>plaats</span>17</a>
      <ul class="nav-links">
        <li><a href="#aanbod">Aanbod</a></li>
        <li><a href="#indeling">Indeling</a></li>
        <li><a href="#tarieven">Tarieven</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>
  </nav>

  <div class="page" id="top">
    <!-- HEADER -->
    <header>
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>Werk<span>plaats</span></h1>
      <p class="tagline">{content.tagline}</p>
    </header>

    <!-- HERO -->
    <div class="hero-image" set:html={heroSvg} />

    <!-- LOCATIE -->
    <div class="location-bar">
      <div class="pin"></div>
      <span>{content.locationText}</span>
    </div>

    <!-- INTRO -->
    <div class="intro">
      <p set:html={content.introText} />
      <div class="access-detail">
        {
          content.accessItems.map((item, i) => (
            <div class="access-item">
              <span class="ico">
                {i === 0 && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                )}
                {i === 1 && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                )}
                {i === 2 && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                )}
              </span>
              {item}
            </div>
          ))
        }
      </div>
    </div>

    <!-- SFEERBEELDEN -->
    <p class="section-label">De werkplaats</p>
    <div class="photo-strip" set:html={photoStripSvg} />

    <!-- AANBOD -->
    <p class="section-label" id="aanbod">Wat je krijgt</p>
    <div class="offer-grid">
      {
        content.offers.map((offer, i) => (
          <div class="offer-card">
            <span class="icon">
              {i === 0 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
              )}
              {i === 1 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 9 2 12 5 15"/><polyline points="19 9 22 12 19 15"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
              )}
              {i === 2 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V21H3V8"/><path d="M23 3H1v5h22V3z"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
              )}
              {i === 3 && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              )}
            </span>
            <h3>{offer.title}</h3>
            <p>{offer.text}</p>
          </div>
        ))
      }
    </div>

    <!-- MACHINES -->
    <p class="section-label">Machines & gereedschap</p>
    <div class="machines-block">
      <div class="machine-list">
        {
          content.machines.map((m) => (
            <span class={'machine-tag' + (m.highlight ? ' highlight' : '')}>{m.name}</span>
          ))
        }
      </div>
    </div>

    <!-- PLATTEGROND -->
    <Floorplan />

    <!-- PRICING -->
    <p class="section-label" id="tarieven">Werkplekken & tarieven</p>
    <div class="pricing-block">
      {
        content.pricing.map((row) => (
          <div class="pricing-row">
            <div>
              <div class="label">{row.label}</div>
              <div class="sub">{row.sub}</div>
            </div>
            <div class="price">
              {row.price}
              <small>{row.unit}</small>
            </div>
          </div>
        ))
      }
    </div>
    <p class="pricing-note">{content.pricingNote}</p>

    <!-- VOOR WIE -->
    <p class="section-label">Voor wie</p>
    <div class="for-who">
      <ul class="criteria-list">
        {
          content.targetAudience.map((item) => (
            <li>
              <span class="check">✦</span> {item}
            </li>
          ))
        }
      </ul>
      <div class="not-for" set:html={content.notForText} />
    </div>

    <!-- CTA -->
    <div class="cta-block" id="contact">
      <h2 set:html={content.ctaHeading} />
      <div class="cta-actions">
        <a href={'mailto:' + content.email} class="btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Mail ons
        </a>
        <a href={whatsappHref} class="btn-secondary" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          WhatsApp
        </a>
      </div>
      <div class="cta-info">
        {
          content.contactLines.map((line, i) => (
            <div class="cta-line">
              <div class="dot"></div>
              {i === 2 ? (
                <span>
                  {line} — <a href={'mailto:' + content.email}>{content.email}</a>
                </span>
              ) : (
                <span>{line}</span>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <!-- INSTAGRAM -->
    <p class="section-label">Volg ons</p>
    <div class="insta-section">
      <div class="insta-grid">
        {
          [0, 1, 2, 3].map(() => (
            <div class="insta-tile">
              <svg class="insta-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </div>
          ))
        }
      </div>
      <div class="insta-handle">
        <a href={content.instagramUrl} target="_blank" rel="noopener">{content.instagramHandle}</a>
      </div>
    </div>

    <!-- FOOTER -->
    <footer>
      <div class="brand">Werk<span>plaats</span>17</div>
      <div class="footer-right">
        <div class="hashtags" set:html={content.hashtags} />
        <div class="copy">{content.copyright}</div>
      </div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      const nav = document.getElementById('stickyNav');
      if (!nav) return;
      const threshold = 280;
      function onScroll() {
        if (window.scrollY > threshold) nav.classList.add('visible');
        else nav.classList.remove('visible');
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>
</BaseLayout>
